# Pulse runtime config
# 1) Get OAuth token: run `claude setup-token` once, paste sk-ant-oat01-... here.
# 2) NEVER set ANTHROPIC_API_KEY — if it is set, SDK ignores OAuth and bills per token.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-REPLACE-ME

# Server
PULSE_HOST=127.0.0.1
PULSE_PORT=8080

# Paths (defaults: repo-relative)
# PULSE_REPO_DIR=/home/pulse/pulse-agent
# PULSE_DATA_DIR=/home/pulse/pulse-agent/data

# Evolution
PULSE_EVOLUTION_INTERVAL_HOURS=12
PULSE_DOWNVOTE_THRESHOLD=5

# Tick (data engine)
PULSE_DAILY_TICK_INTERVAL_HOURS=24

# Budget cap (USD; advisory, Max plan is flat — used to throttle evolution only)
PULSE_BUDGET_DAILY_USD=20.0

# Logging
PULSE_LOG_LEVEL=INFO

# Outbound proxy (uncomment for VMs in regions blocked by Anthropic OAuth Max).
# `claude` CLI honors HTTPS_PROXY/HTTP_PROXY/NO_PROXY — HTTP CONNECT only, no SOCKS.
# Point at a local HTTP proxy (e.g. xray HTTP inbound, sing-box mixed inbound)
# that tunnels to a non-blocked region.
# HTTPS_PROXY=http://127.0.0.1:10809
# HTTP_PROXY=http://127.0.0.1:10809
# NO_PROXY=localhost,127.0.0.1,::1
